   APP_NAME="Enterprise AI Chatbot Platform"
   APP_ENV="development"
   DEBUG=true
   API_V1_STR="/api/v1"
   SECRET_KEY="super-secret-local-key-change-in-prod"
   ACCESS_TOKEN_EXPIRE_MINUTES=30
   REFRESH_TOKEN_EXPIRE_DAYS=7

   POSTGRES_USER="postgres"
   POSTGRES_PASSWORD="postgres"
   POSTGRES_HOST="db"
   POSTGRES_PORT=5432
   POSTGRES_DB="chatbot_db"
   DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/chatbot_db"

   REDIS_HOST="redis"
   REDIS_PORT=6379
   REDIS_PASSWORD=""
   REDIS_URL="redis://redis:6379/0"

   BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'

   # LLM Keys (Leave blank for local testing, the app will use a fallback)
   OPENAI_API_KEY=""
   ANTHROPIC_API_KEY=""
   GOOGLE_API_KEY=""
   OLLAMA_BASE_URL="http://localhost:11434"

   # Vector & Storage Config
   VECTOR_DB_PROVIDER="chroma"
   EMBEDDINGS_PROVIDER="sentence_transformers"
   STORAGE_PROVIDER="local"